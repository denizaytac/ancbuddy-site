# macOS
.DS_Store

# Vite build output (built by GitHub Actions, not committed)
site-src/dist/
site-src/node_modules/

# Logs
*.log
npm-debug.log*

# Local secrets / environment
/.env.local
site-src/.env.local
supabase/.env
supabase/.env.local

# Growth Agent local environment and runtime artifacts
/growth-agent/.env
/growth-agent/.env.local
/growth-agent/.venv/
/growth-agent/.pytest_cache/
/growth-agent/.ruff_cache/
/growth-agent/**/__pycache__/
/growth-agent/evals/results/*.json
!/growth-agent/evals/results/.gitignore

# Local Claude harness config
site-src/.claude/

# Supabase local link/cache metadata
supabase/.temp/

# iCloud/Spotlight duplicates
**/* 2.json
**/* 2.md
**/* 2.txt

# Brand asset backups (local-only safety net)
site-src/public/.brand-backup-*/
