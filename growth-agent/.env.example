# Core runtime
APP_ENV=development
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
CEO_ORIGIN=http://localhost:5173
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# Comma-separated hard blocklist. Reddit stays blocked while the account is suspended.
BLOCKED_CHANNELS=reddit

# CEO authentication. In production use an Argon2 hash, not CEO_PASSWORD.
# Generate: uv run python -c "from argon2 import PasswordHasher; from getpass import getpass; print(PasswordHasher().hash(getpass()))"
CEO_PASSWORD_HASH=
CEO_PASSWORD=
CEO_API_TOKEN=
# Optional ISO-8601 UTC expiry for a temporary mobile access code.
CEO_API_TOKEN_EXPIRES_AT=
SCHEDULER_API_TOKEN=
SESSION_SECRET=
SESSION_TTL_SECONDS=43200
COOKIE_SECURE=false
# "live" only enables the durable worker. Every provider remains disabled until
# it is explicitly enabled in the CEO inbox.
EXECUTION_MODE=simulation

# Goal defaults
GOAL_TARGET=1000
GOAL_EARNED_BASELINE=60
GOAL_CURRENCY=EUR

# Persistence. Use memory only for local development/tests.
STORE_BACKEND=memory
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Agent scheduler (UTC)
SCHEDULER_ENABLED=false
DAILY_RUN_HOUR_UTC=5
DAILY_RUN_MINUTE_UTC=15
DAILY_EXCLUDED_WEEKDAY=0
WEEKLY_RUN_WEEKDAY=0
WEEKLY_RUN_HOUR_UTC=6
WEEKLY_RUN_MINUTE_UTC=15

# AES-GCM key used only on the VPS to encrypt credentials entered in the CEO UI.
# Generate: openssl rand -base64 32
INTEGRATION_ENCRYPTION_KEY=
GITHUB_REPOSITORY=denizaytac/ancbuddy-site
GITHUB_BASE_BRANCH=main
EXECUTION_WORKER_POLL_SECONDS=2
EXECUTION_JOB_LEASE_SECONDS=300
