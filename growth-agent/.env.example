# Core runtime
APP_ENV=development
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
CEO_ORIGIN=http://localhost:5173
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# CEO authentication. In production use an Argon2 hash, not CEO_PASSWORD.
# Generate: uv run python -c "from argon2 import PasswordHasher; from getpass import getpass; print(PasswordHasher().hash(getpass()))"
CEO_PASSWORD_HASH=
CEO_PASSWORD=
CEO_API_TOKEN=
SCHEDULER_API_TOKEN=
SESSION_SECRET=
SESSION_TTL_SECONDS=43200
COOKIE_SECURE=false
EXECUTION_MODE=simulation

# Goal defaults
GOAL_TARGET=1000
GOAL_EARNED_BASELINE=60
GOAL_CURRENCY=EUR

# Persistence. Use memory only for local development/tests.
STORE_BACKEND=memory
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Agent scheduler (UTC)
SCHEDULER_ENABLED=false
DAILY_RUN_HOUR_UTC=7
WEEKLY_RUN_WEEKDAY=0
WEEKLY_RUN_HOUR_UTC=8

# Email execution (optional; approval is still mandatory)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true

# GitHub pull-request execution (optional; approval is still mandatory)
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_BASE_BRANCH=main

# Generic integration for non-email/non-website actions (optional)
GROWTH_WEBHOOK_URL=
GROWTH_WEBHOOK_SECRET=
