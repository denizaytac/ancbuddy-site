# Local-only deployment values. Copy to supabase/.env.local.
# Do not commit real values.

SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=

# Lemon Squeezy API setup. LEMON_STORE_ID is optional when the API key
# can only access one store.
LEMON_API_KEY=
LEMON_STORE_ID=

# Supabase Edge Function secrets. These two are uploaded to Supabase.
LEMON_WEBHOOK_SECRET=
LEMON_EMAIL_HASH_SALT=
