# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored via the *.local pattern in .gitignore.

# Web3Forms access key — get yours at https://web3forms.com
# Used for trial-signup email notifications.
VITE_WEB3FORMS_KEY=

# Supabase project for trial-signup logging.
# Settings → API in the Supabase dashboard.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# CEO Inbox API origin. This is public configuration, never a token.
VITE_GROWTH_AGENT_API_URL=http://localhost:8080

# Local visual QA only. Never enable on the production build.
VITE_GROWTH_DEMO=false
